<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 扫码登录需联网调 qrcodeapi.115.com -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- M2 上传 Worker 走 ForegroundInfo(API 26+)+ API 34+ 必须 type=DATA_SYNC -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- 通知(Android 13+ 需要 run-time 申请 POST_NOTIFICATIONS,M2 暂不实现 -->
    <!-- — Phase 5 接入 UploadRoute 时补 run-time request) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.StarVault"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.StarVault"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            WorkManager Foreground Service — Android 14+ 兼容性声明。

            androidx.work.impl.foreground.SystemForegroundService 默认 manifest 里没声明
            foregroundServiceType,但 UploadWorker.getForegroundInfo() 在 API 34+ 必须传 type=DATA_SYNC
            (M2 spec §4 走数据同步)。运行时 type 必须是 manifest 声明 type 的子集,否则:

              java.lang.IllegalArgumentException: foregroundServiceType 0x00000001 is not a subset
              of foregroundServiceType attribute 0x00000000 in service element of manifest file

            用 tools:node="merge" 覆盖默认 <service> 声明,补 foregroundServiceType="dataSync"。

            参考: https://developer.android.com/develop/background-work/foreground-services#manifest
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!--
            M5 FileProvider — Android Sharesheet 分享图片(PreviewImage MoreMenu → 分享)用。

            仅暴露 cacheDir(FileProvider paths 在 res/xml/file_paths.xml 限定 <cache-path>):
              1. exported="false" — 其他 app 不能主动启动本 provider
              2. grantUriPermissions="true" — 配合 Intent.FLAG_GRANT_READ_URI_PERMISSION
                 临时给 Sharesheet 接收方 app 授予 content:// URI 读权限
              3. authorities = ${applicationId}.fileprovider — applicationId 在
                 app/build.gradle.kts 已设 com.starvault,完整值 com.starvault.fileprovider
            ShareHelper.kt 用此 authorities 拿 FileProvider.getUriForFile(…)。
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
